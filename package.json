{
  "name": "mdv",
  "version": "0.20.6",
  "description": "A terminal markdown viewer with vim keybindings",
  "bin": {
    "mdv": "src/index.ts"
  },
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --compile --outfile mdv",
    "build:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile mdv-darwin-arm64",
    "build:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile mdv-darwin-x64",
    "build:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile mdv-linux-x64",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-x64",
    "install-global": "bun run build && sudo mv mdv /usr/local/bin/",
    "bundle:mermaid": "bun run scripts/bundle-mermaid.ts",
    "bench:scroll": "bun run scripts/bench-scroll.ts",
    "bench:keys": "bun run scripts/bench-keys.ts",
    "bench:reload": "bun run scripts/bench-reload.ts",
    "bench:gen-fixture": "bun run scripts/gen-bench-fixture.ts",
    "bench:commonmark": "bun run scripts/bench-commonmark.ts",
    "regen-golden": "bun run scripts/gen-golden.ts",
    "test": "bun test",
    "lint": "oxlint --ignore-path .oxlintignore",
    "lint:fix": "oxlint --ignore-path .oxlintignore --fix",
    "format": "oxfmt"
  },
  "dependencies": {
    "@opentui/core": "0.1.97",
    "@shikijs/cli": "^3.23.0",
    "entities": "^8.0.0",
    "marked": "^15.0.0",
    "mermaid": "^11.14.0",
    "shiki": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.59.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
